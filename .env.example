# Cesium Ion Token (optional - defaults to community token)
# Get yours at https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Google Maps API Key (optional - for Street View embed)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Upstash Redis (optional - for persistent listing storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenRouteService (optional - for real isochrone polygons)
NEXT_PUBLIC_ORS_KEY=
